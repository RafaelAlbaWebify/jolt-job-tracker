# Run packages: real/private runs stay local; explicit demo runs may be committed only after anonymization.
runs/*
!runs/.gitkeep
!runs/demo_*/
!runs/demo_*/**
runs/real_*/
runs/private_*/

# User-specific profiles are local/private.
backend/config/user_profiles/*
!backend/config/user_profiles/.gitkeep

# Real job-search exports / captures
*.csv
*.xlsx
*.jsonl
*.log

# Safe samples, examples, and demo data may be committed intentionally.
!samples/**/*.csv
!samples/**/*.xlsx
!samples/**/*.json
!samples/**/*.jsonl
!samples/**/*.txt
!samples/**/*.md
!examples/**/*.csv
!examples/**/*.xlsx
!examples/**/*.json
!examples/**/*.jsonl
!examples/**/*.txt
!examples/**/*.md
!demo_data/**/*.csv
!demo_data/**/*.xlsx
!demo_data/**/*.json
!demo_data/**/*.jsonl
!demo_data/**/*.txt
!demo_data/**/*.md
!portfolio_demo/**/*.csv
!portfolio_demo/**/*.xlsx
!portfolio_demo/**/*.json
!portfolio_demo/**/*.jsonl
!portfolio_demo/**/*.txt
!portfolio_demo/**/*.md
